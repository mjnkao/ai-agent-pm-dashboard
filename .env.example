# AICOS RA Railway MCP endpoint (private runtime, aicos-ra).
# aicos-pub is deprecated — all MCP connections now use aicos-ra.
VITE_AICOS_MCP_URL=https://aicos-core-production-0da9.up.railway.app/mcp

# Use token a1-local-03-claude (or another A1 token) from the private handoff file.
# Never commit a real token.
VITE_AICOS_BEARER_TOKEN=<paste-a1-local-03-claude-token-here>
