# AICOS public Railway MCP endpoint.
VITE_AICOS_MCP_URL=https://aicos-pub-production.up.railway.app/mcp

# Never commit a real token. Use a per-agent token such as codex-agent-01,
# claude-agent-01, or openclaw-agent-01 from the private handoff channel.
VITE_AICOS_BEARER_TOKEN=<paste-agent-token-for-local-dev-only>
